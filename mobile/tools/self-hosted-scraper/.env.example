PORT=8788
SELF_HOSTED_SCRAPER_API_KEY=change-me
SELF_HOSTED_TIMEOUT_MS=90000
SELF_HOSTED_MAX_ITEMS=60
SELF_HOSTED_HEADLESS=true
SELF_HOSTED_ATTEMPTS=3
SELF_HOSTED_RETRY_BASE_MS=1500

# 130point (default) vs direct eBay HTML:
SELF_HOSTED_SALES_SOURCE=130point
# SELF_HOSTED_SALES_SOURCE=ebay
# SELF_HOSTED_130POINT_URL=https://130point.com/sales/

# Strongly recommended for 130point on Heroku (Cloudflare). Pick ONE style:
#
# A) Split vars (Playwright):
# SELF_HOSTED_PROXY_SERVER=http://gate.example.com:10001
# SELF_HOSTED_PROXY_USERNAME=your-session-user
# SELF_HOSTED_PROXY_PASSWORD=your-password
#
# B) Decodo residential gateway (same shape; separate from Scraper API credentials):
# DECODO_PROXY_SERVER=http://...
# DECODO_PROXY_USERNAME=...
# DECODO_PROXY_PASSWORD=...
#
# C) Single URL:
# DECODO_PROXY_URL=http://user:pass@gate.example.com:10001
#
# Fail scrapes if 130point mode has no proxy (optional):
# SELF_HOSTED_REQUIRE_PROXY=true

