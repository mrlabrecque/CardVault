# CardHedge — Supabase Edge Functions (`cardhedge-search-cards`, `cardhedge-persist-variant`)
#
# IMPORTANT: Edge Functions do NOT read this file. Add secrets in the Supabase
# dashboard (same project your Flutter app uses):
#
#   Dashboard → Project Settings → Edge Functions → Secrets
#
#   Name:  CARDHEDGE_API_KEY
#   Value: <your CardHedge API key>
#
# Optional alias the code also checks: CARDHEDGER_API_KEY
#
# Catalog card detail calls CardHedge **card-search** only (no card-match):
#   POST https://api.cardhedger.com/v1/cards/card-search
#   Proxied by:  supabase functions deploy cardhedge-search-cards
#
# Persist CardHedge match (image → Storage, `current_prices`, `cardhedge_id`) on catalog variant:
#   supabase functions deploy cardhedge-persist-variant
#
# Optional: min confidence echoed in JSON for the client (default 0.9)
# CARDHEDGE_MATCH_MIN_CONFIDENCE=0.9
#
# Card-search: max CardHedge pages to scan per request (default 10, cap 20)
# CARDHEDGE_SEARCH_MAX_PAGES=10
#
# Logs: rows per `prefilter_sample` / `after_card_number.sample` (default 25, max 80)
# CARDHEDGE_SEARCH_LOG_SAMPLE=25
#
# Verbose Edge logs on upstream JSON (search function can add similar if needed)
# CARDHEDGE_MATCH_LOG_FULL_BODY=1

CARDHEDGE_API_KEY=
